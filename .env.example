# Environment Variables Example
# Copy this file to .env and configure as needed

# Application Settings
APP_LANGUAGE=en_US
APP_THEME=default

# Download Settings
MAX_WORKERS=10
DOWNLOAD_TIMEOUT=30
CONNECT_TIMEOUT=10

# FFmpeg Settings
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Log Settings
LOG_LEVEL=INFO
LOG_FILE=logs/converter.log
